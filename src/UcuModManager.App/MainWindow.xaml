<Window x:Class="UcuModManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="UCU ModManager"
        Height="760"
        Width="1320"
        MinHeight="720"
        MinWidth="1220"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#101010">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#101010" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#141414" />
        <SolidColorBrush x:Key="PanelBrush" Color="#181818" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202020" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#303030" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A8A8A8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#58C7B8" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#061210" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F2C94C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6B6B" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="13,6" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6DD8CA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#43AA9D" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="11,6" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#333333" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#383838" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A52317" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="MetricTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#224D47" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#224D47" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="8,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource MutedTextBrush}"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#2A2A2A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                Background="#4A4A4A"
                                CornerRadius="5" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#6A6A6A" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
            <Grid Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
            <Grid Height="{TemplateBinding Height}" Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="#4A4A4A" />
            <Setter Property="Width" Value="12" />
            <Setter Property="MinWidth" Value="12" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="12" />
                    <Setter Property="MinHeight" Value="12" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#224D47" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#262626" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="24" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#224D47" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#242424" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      Margin="0,0,0,0"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="{StaticResource PanelBrush}" />
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    Padding="0">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Margin="0"
                                                  ContentSource="SelectedContent"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Margin="0,0,4,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#262626" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="UCU ModManager" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="  /  Development Build" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="-"
                            Style="{StaticResource CaptionButton}"
                            Click="Minimize_Click" />
                    <Button Content="[]"
                            Style="{StaticResource CaptionButton}"
                            Click="MaximizeRestore_Click" />
                    <Button Content="x"
                            Style="{StaticResource CloseCaptionButton}"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="22,24,22,18">
                    <TextBlock Text="UCU" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="ModManager" FontSize="18" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <ListBox x:Name="NavigationListBox"
                         SelectedIndex="0"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         Margin="12,0,12,18"
                         SelectionChanged="NavigationListBox_SelectionChanged">
                <ListBoxItem Content="Mods" Tag="Mods" Padding="12,10" />
                <ListBoxItem Content="Profiles" Tag="Profiles" Padding="12,10" />
                    <ListBoxItem Content="Settings" Tag="Settings" Padding="12,10" />
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
        <Grid x:Name="ModsView" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Mods" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="StorageRootText" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="ProfileStatusText" Style="{StaticResource MutedText}" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Install Mods" Style="{StaticResource PrimaryButton}" Click="InstallModArchives_Click" />
                    <Button Content="Install Folder" Style="{StaticResource SecondaryButton}" Click="InstallModFolder_Click" />
                    <Button Content="Check Updates" Style="{StaticResource SecondaryButton}" Click="CheckUpdates_Click" />
                    <Button Content="Update Mods" Style="{StaticResource SecondaryButton}" Click="UpdateMods_Click" />
                    <Button Content="Refresh" Style="{StaticResource SecondaryButton}" Click="Refresh_Click" />
                </WrapPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="#162623"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    Padding="12"
                    Margin="0,0,0,12">
                <DockPanel LastChildFill="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Active Profile" Style="{StaticResource MetricTitle}" />
                            <TextBlock x:Name="ActiveProfileNameText"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ActiveProfileSummaryText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock x:Name="ActiveProfileDeployText"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Game Setup" Style="{StaticResource SectionTitle}" />
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Choose Folder" Style="{StaticResource SecondaryButton}" Click="ChooseGameFolder_Click" />
                            <Button Content="Validate" Style="{StaticResource SecondaryButton}" Click="ValidateGame_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="GameRootText" Grid.Row="2" Style="{StaticResource MutedText}" />
                        <TextBlock x:Name="GameStatusText" Grid.Row="3" Margin="0,5,0,0" TextWrapping="Wrap" FontSize="12" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="BepInEx Setup" Style="{StaticResource SectionTitle}" />
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Install ZIP" Style="{StaticResource SecondaryButton}" Click="InstallBepInExFromZip_Click" />
                            <Button Content="Download" Style="{StaticResource PrimaryButton}" Click="DownloadAndInstallBepInEx_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="BepInExStatusText" Grid.Row="2" TextWrapping="Wrap" FontSize="12" />
                        <TextBlock x:Name="BepInExDetailText" Grid.Row="3" Margin="0,5,0,0" Style="{StaticResource MutedText}" />
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Profile Deploy" Style="{StaticResource SectionTitle}" />
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Clean" Style="{StaticResource SecondaryButton}" Click="CleanDeployment_Click" />
                            <Button Content="Deploy" Style="{StaticResource PrimaryButton}" Click="DeployProfile_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="DeployStatusText" Grid.Row="2" TextWrapping="Wrap" FontSize="12" />
                        <TextBlock x:Name="DeployDetailText" Grid.Row="3" Margin="0,5,0,0" Style="{StaticResource MutedText}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Installed" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="InstalledCountText" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Files" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="FileCountText" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Warnings" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="WarningCountText" Style="{StaticResource MetricValue}" Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9">
                    <StackPanel>
                        <TextBlock Text="Conflicts" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="ConflictCountText" Style="{StaticResource MetricValue}" Foreground="{StaticResource DangerBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,6" LastChildFill="False">
                            <TextBlock Text="Profile Load Order" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="AutoLinkStatusText" Style="{StaticResource MutedText}" DockPanel.Dock="Left" Margin="0,0,12,4" VerticalAlignment="Center" />
                            <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="Link Nexus" Style="{StaticResource SecondaryButton}" Click="LinkNexus_Click" />
                                <Button x:Name="AutoLinkNexusButton" Content="Auto Link Nexus" Style="{StaticResource SecondaryButton}" Click="AutoLinkNexus_Click" />
                                <Button Content="Move Up" Style="{StaticResource SecondaryButton}" Click="MoveUp_Click" />
                                <Button Content="Move Down" Style="{StaticResource SecondaryButton}" Click="MoveDown_Click" />
                                <Button Content="Remove Mod" Style="{StaticResource SecondaryButton}" Click="RemoveSelectedMod_Click" />
                            </WrapPanel>
                        </DockPanel>
                        <ListView x:Name="ModsListView" Grid.Row="1" SelectionChanged="ModsListView_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="On" Width="48">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Click="EnabledCheckBox_Click" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Order" Width="54" DisplayMemberBinding="{Binding Priority}" />
                                    <GridViewColumn Header="Mod" Width="160" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Version" Width="76" DisplayMemberBinding="{Binding Version}" />
                                    <GridViewColumn Header="Files" Width="54" DisplayMemberBinding="{Binding FileCount}" />
                                    <GridViewColumn Header="Plugins" Width="64" DisplayMemberBinding="{Binding PluginCount}" />
                                    <GridViewColumn Header="Content" Width="66" DisplayMemberBinding="{Binding ContentFileCount}" />
                                    <GridViewColumn Header="Configs" Width="62" DisplayMemberBinding="{Binding ProfileConfigCount}" />
                                    <GridViewColumn Header="Refs" Width="50" DisplayMemberBinding="{Binding DependencyStatus}" />
                                    <GridViewColumn Header="Updates" Width="102" DisplayMemberBinding="{Binding UpdateStatus}" />
                                    <GridViewColumn Header="Status" Width="86" DisplayMemberBinding="{Binding Status}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="48"
                                    Height="48"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <Image x:Name="SelectedModImage" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="SelectedModNameText" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedModIdText" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedModAuthorText" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                <DockPanel Margin="0,5,0,0" LastChildFill="True">
                                    <Button x:Name="OpenSelectedModNexusButton"
                                            Content="Open Nexus"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OpenSelectedModNexus_Click"
                                            DockPanel.Dock="Left" />
                                    <TextBlock x:Name="SelectedModNexusText" Style="{StaticResource MutedText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Files" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedFileCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Plugins" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedPluginCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Content" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedContentCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Warnings" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedWarningCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <TabControl Grid.Row="2">
                            <TabItem Header="Dependencies">
                                <ListView x:Name="DependenciesListView">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Assembly" Width="150" DisplayMemberBinding="{Binding AssemblyName}" />
                                            <GridViewColumn Header="Status" Width="86" DisplayMemberBinding="{Binding Status}" />
                                            <GridViewColumn Header="Provider" Width="110" DisplayMemberBinding="{Binding Providers}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </TabItem>
                            <TabItem Header="Overlay">
                                <ListView x:Name="OverlayListView">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Status" Width="96" DisplayMemberBinding="{Binding Status}" />
                                            <GridViewColumn Header="Kind" Width="132" DisplayMemberBinding="{Binding DisplayKind}" />
                                            <GridViewColumn Header="Target" Width="250" DisplayMemberBinding="{Binding TargetRelativePath}" />
                                            <GridViewColumn Header="Mod" Width="130" DisplayMemberBinding="{Binding OwningModId}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </TabItem>
                            <TabItem Header="Warnings">
                                <ListBox x:Name="WarningsListBox" />
                            </TabItem>
                            <TabItem Header="Nexus">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,4,8,0">
                                        <Border Height="160"
                                                Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource BorderBrushDark}"
                                                BorderThickness="1"
                                                Margin="0,0,0,10">
                                            <Image x:Name="SelectedModLargeImage" Stretch="UniformToFill" />
                                        </Border>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Version" Style="{StaticResource MutedText}" />
                                                <TextBlock x:Name="SelectedNexusVersionText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Downloads" Style="{StaticResource MutedText}" />
                                                <TextBlock x:Name="SelectedNexusDownloadsText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="SelectedNexusStatsText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                        <TextBlock Text="Description" Style="{StaticResource MutedText}" />
                                        <TextBlock x:Name="SelectedNexusDescriptionText" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ProfilesView" Margin="22" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Profiles" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="ProfilePageStatusText" Style="{StaticResource MutedText}" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="New" Style="{StaticResource PrimaryButton}" Click="CreateProfile_Click" />
                    <Button Content="Duplicate" Style="{StaticResource SecondaryButton}" Click="DuplicateProfile_Click" />
                    <Button Content="Delete" Style="{StaticResource SecondaryButton}" Click="DeleteProfile_Click" />
                </WrapPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Profile List" Style="{StaticResource SectionTitle}" />
                        <ListBox x:Name="ProfilesListBox"
                                 Grid.Row="1"
                                 DisplayMemberPath="Name"
                                 SelectionChanged="ProfilesListBox_SelectionChanged" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Active Profile" Style="{StaticResource SectionTitle}" />

                        <Grid Grid.Row="1" Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Name"
                                       Style="{StaticResource MetricTitle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBox x:Name="ProfileNameTextBox"
                                     Grid.Column="1"
                                     Height="30" />
                            <Button Grid.Column="2"
                                    Content="Rename"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    Click="RenameProfile_Click" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Installed" Style="{StaticResource MetricTitle}" />
                                    <TextBlock x:Name="ProfileInstalledCountText" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Enabled" Style="{StaticResource MetricTitle}" />
                                    <TextBlock x:Name="ProfileEnabledCountText" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="12,9">
                                <StackPanel>
                                    <TextBlock Text="Deployed" Style="{StaticResource MetricTitle}" />
                                    <TextBlock x:Name="ProfileDeployedCountText" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ListBox x:Name="ProfileDetailsListBox" Grid.Row="3" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="SettingsView" Margin="22" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Manager preferences and service connections" Style="{StaticResource MutedText}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Padding="12"
                    MaxWidth="680"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Nexus Mods" Style="{StaticResource SectionTitle}" />
                    <TextBlock Grid.Row="1"
                               Text="API key"
                               Style="{StaticResource MetricTitle}"
                               Margin="0,4,0,4" />
                    <PasswordBox x:Name="NexusApiKeyPasswordBox"
                                 Grid.Row="2"
                                 Height="30"
                                 Width="420"
                                 HorizontalAlignment="Left" />
                    <TextBlock Grid.Row="3"
                               Text="Game domain"
                               Style="{StaticResource MetricTitle}"
                               Margin="0,10,0,4" />
                    <TextBox x:Name="NexusGameDomainTextBox"
                             Grid.Row="4"
                             Height="30"
                             Width="260"
                             HorizontalAlignment="Left" />
                    <DockPanel Grid.Row="5" Margin="0,10,0,0" LastChildFill="True">
                        <WrapPanel DockPanel.Dock="Left">
                            <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="SaveNexusApiKey_Click" />
                            <Button Content="Test" Style="{StaticResource SecondaryButton}" Click="TestNexusApiKey_Click" />
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}" Click="ClearNexusApiKey_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="NexusApiKeyStatusText"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>

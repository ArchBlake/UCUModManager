<Window x:Class="UcuModManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="UCU ModManager"
        Height="840"
        Width="1440"
        MinHeight="720"
        MinWidth="1220"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#101010"
        FontFamily="Segoe UI"
        FontSize="12"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#101010" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#141414" />
        <SolidColorBrush x:Key="PanelBrush" Color="#181818" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202020" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#303030" />
        <SolidColorBrush x:Key="SubtleBorderBrush" Color="#252525" />
        <SolidColorBrush x:Key="HoverBrush" Color="#252525" />
        <SolidColorBrush x:Key="PressedBrush" Color="#303030" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#1F4B45" />
        <SolidColorBrush x:Key="SelectedSoftBrush" Color="#182D2A" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A8A8A8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#58C7B8" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#061210" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F2C94C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6B6B" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="MinHeight" Value="31" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6DD8CA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#43AA9D" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.48" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="31" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}" />
                    <Setter Property="BorderBrush" Value="#3A3A3A" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.48" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#383838" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A52317" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="MetricTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="CheckBoxBorder"
                                        Width="15"
                                        Height="15"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <Path x:Name="CheckMark"
                                          Data="M 3 7 L 6 10 L 12 3"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Square"
                                          StrokeEndLineCap="Square"
                                          Visibility="Collapsed" />
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{StaticResource SelectedSoftBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#224D47" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#224D47" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="8,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource MutedTextBrush}"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="2"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                Background="#4A4A4A"
                                CornerRadius="5" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#6A6A6A" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
            <Grid Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
            <Grid Height="{TemplateBinding Height}" Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource ScrollBarPageButton}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="#4A4A4A" />
            <Setter Property="Width" Value="12" />
            <Setter Property="MinWidth" Value="12" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="12" />
                    <Setter Property="MinHeight" Value="12" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBox}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Padding="{TemplateBinding Padding}"
                                          Focusable="False"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="SelectionRail"
                                        Width="3"
                                        Margin="-4,3,0,3"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="2"
                                        Opacity="0" />
                                <ContentPresenter Margin="6,0,0,0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectedSoftBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#315F59" />
                                <Setter TargetName="SelectionRail" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListView}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Padding="{TemplateBinding Padding}"
                                          Focusable="False"
                                          Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SelectedBrush}" />
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="#3D6E68" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Thumb x:Name="PART_HeaderGripper"
                                       Width="8"
                                       HorizontalAlignment="Right"
                                       Background="Transparent"
                                       Cursor="SizeWE" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="Role" Value="Padding">
                                <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,0,1" />
                                <Setter TargetName="PART_HeaderGripper" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      Margin="0,0,0,0"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="{StaticResource PanelBrush}" />
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="0,6,6,6"
                                    Padding="0">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Margin="0"
                                                  ContentSource="SelectedContent"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Margin="0,0,4,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5,5,0,0"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Width="4"
                            Height="18"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="2"
                            Margin="0,0,10,0" />
                    <TextBlock Text="UCU ModManager" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Development Build"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,1,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;"
                            Style="{StaticResource CaptionButton}"
                            Click="Minimize_Click" />
                    <Button Content="&#xE922;"
                            Style="{StaticResource CaptionButton}"
                            Click="MaximizeRestore_Click" />
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource CloseCaptionButton}"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource SubtleBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="22,24,22,20">
                    <TextBlock Text="UCU" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="ModManager" FontSize="16" Foreground="{StaticResource MutedTextBrush}" Margin="0,-1,0,0" />
                </StackPanel>

                <ListBox x:Name="NavigationListBox"
                         SelectedIndex="0"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         Margin="12,0,12,18"
                         SelectionChanged="NavigationListBox_SelectionChanged">
                    <ListBoxItem Content="Mods" Tag="Mods" Padding="12,10" />
                    <ListBoxItem Content="Profiles" Tag="Profiles" Padding="12,10" />
                    <ListBoxItem Content="Nexus Mods" Tag="NexusBrowser" Padding="12,10" />
                    <ListBoxItem Content="Modpacks" Tag="Modpacks" Padding="12,10" />
                    <ListBoxItem Content="Settings" Tag="Settings" Padding="12,10" />
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
        <Grid x:Name="ModsView" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Mods" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="StorageRootText" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="ProfileStatusText" Style="{StaticResource MutedText}" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Install Mods" Style="{StaticResource PrimaryButton}" Click="InstallModArchives_Click" />
                    <Button Content="Install Folder" Style="{StaticResource SecondaryButton}" Click="InstallModFolder_Click" />
                    <Button x:Name="ToggleAllModsButton"
                            Content="Enable All"
                            Style="{StaticResource SecondaryButton}"
                            Click="ToggleAllMods_Click" />
                    <Button Content="Check Updates" Style="{StaticResource SecondaryButton}" Click="CheckUpdates_Click" />
                    <Button Content="Update Mods" Style="{StaticResource SecondaryButton}" Click="UpdateMods_Click" />
                    <Button Content="Refresh" Style="{StaticResource SecondaryButton}" Click="Refresh_Click" />
                </WrapPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Background="#162623"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="7"
                    Padding="12"
                    Margin="0,0,0,12">
                <DockPanel LastChildFill="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Active Profile" Style="{StaticResource MetricTitle}" />
                            <TextBlock x:Name="ActiveProfileNameText"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ActiveProfileSummaryText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock x:Name="ActiveProfileDeployText"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Game Setup" Style="{StaticResource SectionTitle}" />
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Choose Folder" Style="{StaticResource SecondaryButton}" Click="ChooseGameFolder_Click" />
                            <Button Content="Validate" Style="{StaticResource SecondaryButton}" Click="ValidateGame_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="GameRootText" Grid.Row="2" Style="{StaticResource MutedText}" />
                        <TextBlock x:Name="GameStatusText" Grid.Row="3" Margin="0,5,0,0" TextWrapping="Wrap" FontSize="12" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="BepInEx Setup" Style="{StaticResource SectionTitle}" />
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Install ZIP" Style="{StaticResource SecondaryButton}" Click="InstallBepInExFromZip_Click" />
                            <Button Content="Download" Style="{StaticResource PrimaryButton}" Click="DownloadAndInstallBepInEx_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="BepInExStatusText" Grid.Row="2" TextWrapping="Wrap" FontSize="12" />
                        <TextBlock x:Name="BepInExDetailText" Grid.Row="3" Margin="0,5,0,0" Style="{StaticResource MutedText}" />
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Profile Deploy" Style="{StaticResource SectionTitle}" />
                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <Button Content="Clean" Style="{StaticResource SecondaryButton}" Click="CleanDeployment_Click" />
                            <Button Content="Deploy" Style="{StaticResource PrimaryButton}" Click="DeployProfile_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="DeployStatusText" Grid.Row="2" TextWrapping="Wrap" FontSize="12" />
                        <TextBlock x:Name="DeployDetailText" Grid.Row="3" Margin="0,5,0,0" Style="{StaticResource MutedText}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Installed" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="InstalledCountText" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Files" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="FileCountText" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Warnings" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="WarningCountText" Style="{StaticResource MetricValue}" Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9">
                    <StackPanel>
                        <TextBlock Text="Conflicts" Style="{StaticResource MetricTitle}" />
                        <TextBlock x:Name="ConflictCountText" Style="{StaticResource MetricValue}" Foreground="{StaticResource DangerBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,6" LastChildFill="False">
                            <TextBlock Text="Profile Load Order" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="AutoLinkStatusText" Style="{StaticResource MutedText}" DockPanel.Dock="Left" Margin="0,0,12,4" VerticalAlignment="Center" />
                            <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="Link Nexus" Style="{StaticResource SecondaryButton}" Click="LinkNexus_Click" />
                                <Button x:Name="AutoLinkNexusButton" Content="Auto Link Nexus" Style="{StaticResource SecondaryButton}" Click="AutoLinkNexus_Click" />
                                <Button Content="Move Up" Style="{StaticResource SecondaryButton}" Click="MoveUp_Click" />
                                <Button Content="Move Down" Style="{StaticResource SecondaryButton}" Click="MoveDown_Click" />
                                <Button Content="Remove Mod" Style="{StaticResource SecondaryButton}" Click="RemoveSelectedMod_Click" />
                            </WrapPanel>
                        </DockPanel>
                        <ListView x:Name="ModsListView" Grid.Row="1" SelectionChanged="ModsListView_SelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="On" Width="52">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Click="EnabledCheckBox_Click" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Order" Width="66" DisplayMemberBinding="{Binding Priority}" />
                                    <GridViewColumn Header="Mod" Width="190" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Version" Width="88" DisplayMemberBinding="{Binding Version}" />
                                    <GridViewColumn Header="Files" Width="62" DisplayMemberBinding="{Binding FileCount}" />
                                    <GridViewColumn Header="Plugins" Width="78" DisplayMemberBinding="{Binding PluginCount}" />
                                    <GridViewColumn Header="Content" Width="82" DisplayMemberBinding="{Binding ContentFileCount}" />
                                    <GridViewColumn Header="Configs" Width="80" DisplayMemberBinding="{Binding ProfileConfigCount}" />
                                    <GridViewColumn Header="Refs" Width="64" DisplayMemberBinding="{Binding DependencyStatus}" />
                                    <GridViewColumn Header="Updates" Width="118" DisplayMemberBinding="{Binding UpdateStatus}" />
                                    <GridViewColumn Header="Status" Width="96" DisplayMemberBinding="{Binding Status}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="48"
                                    Height="48"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <Image x:Name="SelectedModImage" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="SelectedModNameText" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedModIdText" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedModAuthorText" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                <DockPanel Margin="0,5,0,0" LastChildFill="True">
                                    <Button x:Name="OpenSelectedModNexusButton"
                                            Content="Open Nexus"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="OpenSelectedModNexus_Click"
                                            DockPanel.Dock="Left" />
                                    <TextBlock x:Name="SelectedModNexusText" Style="{StaticResource MutedText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Files" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedFileCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Plugins" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedPluginCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Content" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedContentCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Warnings" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SelectedWarningCountText" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <TabControl Grid.Row="2">
                            <TabItem Header="Dependencies">
                                <ListView x:Name="DependenciesListView">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Assembly" Width="150" DisplayMemberBinding="{Binding AssemblyName}" />
                                            <GridViewColumn Header="Status" Width="86" DisplayMemberBinding="{Binding Status}" />
                                            <GridViewColumn Header="Provider" Width="110" DisplayMemberBinding="{Binding Providers}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </TabItem>
                            <TabItem Header="Overlay">
                                <ListView x:Name="OverlayListView">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Status" Width="96" DisplayMemberBinding="{Binding Status}" />
                                            <GridViewColumn Header="Kind" Width="132" DisplayMemberBinding="{Binding DisplayKind}" />
                                            <GridViewColumn Header="Target" Width="250" DisplayMemberBinding="{Binding TargetRelativePath}" />
                                            <GridViewColumn Header="Mod" Width="130" DisplayMemberBinding="{Binding OwningModId}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </TabItem>
                            <TabItem Header="Warnings">
                                <ListBox x:Name="WarningsListBox" />
                            </TabItem>
                            <TabItem Header="Nexus">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,4,8,0">
                                        <Border Height="160"
                                                Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Margin="0,0,0,10">
                                            <Image x:Name="SelectedModLargeImage" Stretch="UniformToFill" />
                                        </Border>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Version" Style="{StaticResource MutedText}" />
                                                <TextBlock x:Name="SelectedNexusVersionText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Downloads" Style="{StaticResource MutedText}" />
                                                <TextBlock x:Name="SelectedNexusDownloadsText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="SelectedNexusStatsText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                        <DockPanel Margin="0,0,0,6" LastChildFill="False">
                                            <TextBlock Text="Files" Style="{StaticResource MutedText}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                            <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                <Button x:Name="RefreshNexusFilesButton"
                                                        Content="Refresh Files"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="RefreshNexusFiles_Click" />
                                                <Button x:Name="DownloadSelectedNexusFileButton"
                                                        Content="Download Selected"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="DownloadSelectedNexusFile_Click" />
                                                <Button x:Name="OpenSelectedModFilesPageButton"
                                                        Content="Open Files Page"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="OpenSelectedModFilesPage_Click" />
                                            </WrapPanel>
                                        </DockPanel>
                                        <TextBlock x:Name="SelectedNexusFilesStatusText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                        <ListView x:Name="NexusFilesListView"
                                                  Height="170"
                                                  Margin="0,0,0,10"
                                                  SelectionChanged="NexusFilesListView_SelectionChanged">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Category" Width="84" DisplayMemberBinding="{Binding Category}" />
                                                    <GridViewColumn Header="File" Width="150" DisplayMemberBinding="{Binding FileName}" />
                                                    <GridViewColumn Header="Version" Width="76" DisplayMemberBinding="{Binding Version}" />
                                                    <GridViewColumn Header="Uploaded" Width="88" DisplayMemberBinding="{Binding Uploaded}" />
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                        <TextBlock Text="Description" Style="{StaticResource MutedText}" />
                                        <TextBlock x:Name="SelectedNexusDescriptionText" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ProfilesView" Margin="22" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Profiles" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="ProfilePageStatusText" Style="{StaticResource MutedText}" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="New" Style="{StaticResource PrimaryButton}" Click="CreateProfile_Click" />
                    <Button Content="Duplicate" Style="{StaticResource SecondaryButton}" Click="DuplicateProfile_Click" />
                    <Button Content="Delete" Style="{StaticResource SecondaryButton}" Click="DeleteProfile_Click" />
                </WrapPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Profile List" Style="{StaticResource SectionTitle}" />
                        <ListBox x:Name="ProfilesListBox"
                                 Grid.Row="1"
                                 DisplayMemberPath="Name"
                                 SelectionChanged="ProfilesListBox_SelectionChanged" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Active Profile" Style="{StaticResource SectionTitle}" />

                        <Grid Grid.Row="1" Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Name"
                                       Style="{StaticResource MetricTitle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBox x:Name="ProfileNameTextBox"
                                     Grid.Column="1"
                                     Height="30" />
                            <Button Grid.Column="2"
                                    Content="Rename"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    Click="RenameProfile_Click" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Installed" Style="{StaticResource MetricTitle}" />
                                    <TextBlock x:Name="ProfileInstalledCountText" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Enabled" Style="{StaticResource MetricTitle}" />
                                    <TextBlock x:Name="ProfileEnabledCountText" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12,9">
                                <StackPanel>
                                    <TextBlock Text="Deployed" Style="{StaticResource MetricTitle}" />
                                    <TextBlock x:Name="ProfileDeployedCountText" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ListBox x:Name="ProfileDetailsListBox" Grid.Row="3" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="NexusBrowserView" Margin="22" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Nexus Mods" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="NexusCatalogStatusText" Style="{StaticResource MutedText}" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button x:Name="RefreshNexusCatalogButton" Content="Refresh Catalog" Style="{StaticResource SecondaryButton}" Click="RefreshNexusCatalog_Click" />
                    <Button x:Name="DownloadNexusCatalogButton" Content="Download" Style="{StaticResource PrimaryButton}" Click="DownloadNexusCatalog_Click" />
                    <Button x:Name="OpenNexusCatalogButton" Content="Open Nexus" Style="{StaticResource SecondaryButton}" Click="OpenNexusCatalog_Click" />
                </WrapPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" Style="{StaticResource MetricTitle}" VerticalAlignment="Center" />
                <TextBox x:Name="NexusCatalogSearchTextBox"
                         Grid.Column="1"
                         Height="30"
                         TextChanged="NexusCatalogSearchTextBox_TextChanged" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,12,0">
                    <ListView x:Name="NexusCatalogListView" SelectionChanged="NexusCatalogListView_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Mod" Width="240" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Version" Width="88" DisplayMemberBinding="{Binding Version}" />
                                <GridViewColumn Header="Author" Width="140" DisplayMemberBinding="{Binding Author}" />
                                <GridViewColumn Header="Downloads" Width="92" DisplayMemberBinding="{Binding Downloads}" />
                                <GridViewColumn Header="Status" Width="92" DisplayMemberBinding="{Binding Status}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Height="150"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,0,10">
                                <Image x:Name="NexusCatalogImage" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock x:Name="NexusCatalogNameText" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="NexusCatalogMetaText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,6" />
                            <TextBlock x:Name="NexusCatalogStatsText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                            <TextBlock Text="Description" Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="NexusCatalogDescriptionText" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ModpacksView" Margin="22" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Modpacks" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="ModpacksStatusText" Style="{StaticResource MutedText}" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Export .UCU" Style="{StaticResource PrimaryButton}" Click="ExportUcuModpack_Click" />
                    <Button Content="Export .UCUP" Style="{StaticResource SecondaryButton}" Click="ExportUcupModpack_Click" />
                    <Button Content="Import Modpack" Style="{StaticResource SecondaryButton}" Click="ImportUcuModpack_Click" />
                </WrapPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="106" />
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Export profile"
                           Style="{StaticResource MetricTitle}"
                           VerticalAlignment="Center" />
                <ComboBox x:Name="ModpackExportProfileComboBox"
                          Grid.Column="1"
                          Height="30"
                          DisplayMemberPath="Name" />
            </Grid>

            <TextBlock Grid.Row="2"
                       Text=".UCU stores a Nexus recipe. .UCUP stores the profile and mod files inside one portable modpack."
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10" />

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,12,0">
                    <ListView x:Name="ImportedUcuModpackListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Order" Width="58" DisplayMemberBinding="{Binding Priority}" />
                                <GridViewColumn Header="Mod" Width="240" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Version" Width="90" DisplayMemberBinding="{Binding Version}" />
                                <GridViewColumn Header="Enabled" Width="72" DisplayMemberBinding="{Binding Enabled}" />
                                <GridViewColumn Header="Source" Width="130" DisplayMemberBinding="{Binding Source}" />
                                <GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding Status}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Imported Modpack" Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="ImportedUcuNameText" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,4" />
                        <TextBlock x:Name="ImportedUcuPathText" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        <TextBlock x:Name="ImportedUcuSummaryText" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <WrapPanel>
                            <Button x:Name="InstallImportedUcuModpackButton"
                                    Content="Install Modpack"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="InstallImportedUcuModpack_Click" />
                            <Button x:Name="OpenImportedUcuPagesButton"
                                    Content="Open All Nexus Pages"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OpenImportedUcuPages_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="SettingsView" Margin="22" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Manager preferences and service connections" Style="{StaticResource MutedText}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    MaxWidth="680"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Nexus Mods" Style="{StaticResource SectionTitle}" />
                    <TextBlock Grid.Row="1"
                               Text="API key"
                               Style="{StaticResource MetricTitle}"
                               Margin="0,4,0,4" />
                    <PasswordBox x:Name="NexusApiKeyPasswordBox"
                                 Grid.Row="2"
                                 Height="30"
                                 Width="420"
                                 HorizontalAlignment="Left" />
                    <TextBlock Grid.Row="3"
                               Text="Game domain"
                               Style="{StaticResource MetricTitle}"
                               Margin="0,10,0,4" />
                    <TextBox x:Name="NexusGameDomainTextBox"
                             Grid.Row="4"
                             Height="30"
                             Width="260"
                             HorizontalAlignment="Left" />
                    <CheckBox x:Name="AutoLinkNexusOnStartupCheckBox"
                              Grid.Row="5"
                              Content="Auto link Nexus metadata on startup"
                              Margin="0,12,0,0"
                              Checked="AutoLinkNexusOnStartupCheckBox_Changed"
                              Unchecked="AutoLinkNexusOnStartupCheckBox_Changed" />
                    <TextBlock Grid.Row="6"
                               Text="When enabled, UCU ModManager links installed mods to Nexus metadata after startup without asking."
                               Style="{StaticResource MutedText}"
                               Margin="23,4,0,0" />
                    <DockPanel Grid.Row="7" Margin="0,10,0,0" LastChildFill="True">
                        <WrapPanel DockPanel.Dock="Left">
                            <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="SaveNexusApiKey_Click" />
                            <Button Content="Test" Style="{StaticResource SecondaryButton}" Click="TestNexusApiKey_Click" />
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}" Click="ClearNexusApiKey_Click" />
                        </WrapPanel>
                        <TextBlock x:Name="NexusApiKeyStatusText"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>
